@model IEnumerable<DietitianApp.Models.DietitianProfile>
@{
    ViewData["Title"] = "Admin Paneli - Onay Bekleyen Diyetisyenler";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="bi bi-shield-lock-fill me-2"></i> Yönetim Paneli</h2>
        <span class="badge bg-warning text-dark px-3 py-2 fs-6 rounded-pill">Bekleyen Onaylar: @Model.Count()</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Ad Soyad</th>
                            <th>E-Posta</th>
                            <th>Kayıt Tarihi</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                    Onay bekleyen diyetisyen bulunmamaktadır.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-medium">@item.User?.Name @item.User?.Surname</td>
                                    <td class="text-muted">@item.User?.Email</td>
                                    <td>@item.User?.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <form asp-action="ApproveDietitian" method="post" class="d-inline">
                                            <input type="hidden" name="profileId" value="@item.Id" />
                                            <button type="submit" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm">
                                                <i class="bi bi-check-lg me-1"></i> Onayla
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
