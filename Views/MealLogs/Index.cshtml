@model IEnumerable<DietitianApp.Models.MealLog>
@{
    ViewData["Title"] = "Öğün Takibim";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold"><i class="bi bi-egg-fried me-2"></i> Günlük Öğün Takibim</h2>
    <a asp-controller="Clients" asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Geri Dön
    </a>
</div>

<div class="row g-4">
    <!-- Ögün Ekleme Formu -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 rounded-4 sticky-top" style="top: 100px;">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Yeni Öğün Ekle</h5>
                <form asp-action="Add" method="post">
                    
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Öğün Türü</label>
                        <select name="MealType" class="form-select focus-ring focus-ring-success rounded-pill" required>
                            <option value="Kahvaltı">☀️ Kahvaltı</option>
                            <option value="Öğle Yemeği">🍽️ Öğle Yemeği</option>
                            <option value="Akşam Yemeği">🌙 Akşam Yemeği</option>
                            <option value="Ara Öğün">🍎 Ara Öğün</option>
                            <option value="Su/İçecek">💧 Su / İçecek</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Neler Yedin?</label>
                        <textarea name="Description" class="form-control focus-ring focus-ring-success rounded-4" rows="4" placeholder="Örn: 2 dilim tam buğday ekmeği, 3 zeytin..." required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2">
                        <i class="bi bi-plus-circle me-1"></i> Öğünü Kaydet
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Geçmiş Öğünler Listesi -->
    <div class="col-lg-8">
        @if (!Model.Any())
        {
            <div class="card shadow-sm border-0 rounded-4 text-center py-5 h-100 d-flex justify-content-center align-items-center">
                <div>
                    <i class="bi bi-pencil-square fs-1 text-muted d-block mb-3"></i>
                    <h5 class="text-muted">Bugün henüz bir şey yemediniz mi?</h5>
                    <p class="text-muted small">Öğünlerinizi kaydederek gelişiminizi takip edin.</p>
                </div>
            </div>
        }
        else
        {
            <div class="timeline ps-2">
                @foreach (var group in Model.GroupBy(m => m.LogDate.Date).OrderByDescending(g => g.Key))
                {
                    <h5 class="fw-bold text-secondary mt-4 mb-3">
                        @if(group.Key == DateTime.Now.Date) { <span class="badge bg-success me-2">Bugün</span> }
                        else if(group.Key == DateTime.Now.Date.AddDays(-1)) { <span class="badge bg-secondary me-2">Dün</span> }
                        else { @group.Key.ToString("dd MMMM yyyy") }
                    </h5>
                    
                    @foreach(var log in group)
                    {
                        <div class="card shadow-sm border-0 rounded-4 mb-3">
                            <div class="card-body p-3 px-4 d-flex">
                                <!-- Type Icon Background -->
                                <div class="me-3 mt-1">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        @if(log.MealType == "Kahvaltı") { <i class="bi bi-sunrise fs-4"></i> }
                                        else if(log.MealType == "Öğle Yemeği") { <i class="bi bi-sun fs-4"></i> }
                                        else if(log.MealType == "Akşam Yemeği") { <i class="bi bi-moon fs-4"></i> }
                                        else if(log.MealType == "Ara Öğün") { <i class="bi bi-apple fs-4"></i> }
                                        else { <i class="bi bi-cup-straw fs-4"></i> }
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="fw-bold mb-0 text-dark">@log.MealType</h6>
                                        <span class="text-muted small">@log.LogDate.ToString("HH:mm")</span>
                                    </div>
                                    <p class="text-muted mb-0">@log.Description</p>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>
