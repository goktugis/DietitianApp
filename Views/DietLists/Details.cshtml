@model DietitianApp.Models.DietList
@{
    ViewData["Title"] = Model.Title;
    var isClient = User.IsInRole("Client");
}

<div class="container mt-4">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="fw-bold text-primary display-6">@Model.Title</h1>
            <p class="text-muted fs-5 mb-0">
                <i class="bi bi-calendar-range me-2"></i> @Model.ValidFrom.ToString("dd MMM yyyy") - @Model.ValidUntil.ToString("dd MMM yyyy")
            </p>
            @if(isClient)
            {
                <span class="badge bg-success bg-opacity-10 text-success fs-6 mt-2 px-3 py-2 rounded-pill">
                    <i class="bi bi-person-badge me-1"></i> Diyetisyeniniz: @Model.Dietitian?.Name @Model.Dietitian?.Surname
                </span>
            }
            else
            {
                <span class="badge bg-primary bg-opacity-10 text-primary fs-6 mt-2 px-3 py-2 rounded-pill">
                    <i class="bi bi-person-heart me-1"></i> Danışan: @Model.Client?.Name @Model.Client?.Surname
                </span>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Content))
    {
        <div class="card shadow-sm border-0 rounded-4 mb-5">
            <div class="card-body p-4 bg-light rounded-4">
                <h5 class="fw-bold text-dark mb-3"><i class="bi bi-info-circle me-2"></i> Genel Notlar</h5>
                <p class="text-muted mb-0" style="white-space: pre-line;">@Model.Content</p>
            </div>
        </div>
    }

    <h4 class="fw-bold text-dark mb-4 border-bottom pb-2"><i class="bi bi-calendar-week me-2"></i> Haftalık Diyet Programı</h4>

    @if (Model.Meals == null || !Model.Meals.Any())
    {
        <div class="alert alert-info text-center rounded-4 py-4 shadow-sm mb-5">
            <i class="bi bi-cup-hot fs-1 d-block mb-3"></i>
            Bu liste için belirli bir öğün girişi yapılmamış. Yalnızca genel notlar üzerinden ilerleyebilirsiniz.
        </div>
    }
    else
    {
        var groupedMeals = Model.Meals.GroupBy(m => string.IsNullOrEmpty(m.DayName) ? "Her Gün" : m.DayName).ToList();
        var daysOrder = new List<string> { "Pazartesi", "Salı", "Çarşamba", "Perşembe", "Cuma", "Cumartesi", "Pazar", "Her Gün" };
        var activeDays = groupedMeals.Select(g => g.Key).OrderBy(d => {
            var idx = daysOrder.IndexOf(d);
            return idx == -1 ? 99 : idx;
        }).ToList();

        <ul class="nav nav-pills nav-fill bg-light p-1 rounded-pill mb-4" id="detailTabs" role="tablist">
            @foreach (var day in activeDays)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link rounded-pill fw-bold @(day == activeDays.First() ? "active" : "text-muted")" id="tab-@day.Replace(" ", "")" data-bs-toggle="pill" data-bs-target="#pane-@day.Replace(" ", "")" type="button" role="tab">@day</button>
                </li>
            }
        </ul>

        <div class="tab-content mb-5" id="detailTabsContent">
            @foreach (var group in groupedMeals)
            {
                var day = group.Key;
                <div class="tab-pane fade @(day == activeDays.First() ? "show active" : "")" id="pane-@day.Replace(" ", "")" role="tabpanel">
                    <div class="table-responsive bg-white rounded-4 shadow-sm border p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4 py-3 text-muted">Saat</th>
                                    <th class="py-3 text-muted">Öğün</th>
                                    <th class="py-3 text-muted w-50">İçerik Yönergeleri</th>
                                    <th class="pe-4 py-3 text-center text-muted">Durum / İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var meal in group.OrderBy(m => m.Time))
                                {
                                    <tr class="@(meal.IsCompleted ? "table-success bg-opacity-10" : "")">
                                        <td class="ps-4 fw-bold text-dark fs-5">
                                            <i class="bi bi-clock text-muted fs-6 me-1"></i> @meal.Time.ToString(@"hh\:mm")
                                        </td>
                                        <td>
                                            <span class="badge @(meal.IsCompleted ? "bg-success" : "bg-primary") rounded-pill px-3 py-2">@meal.MealName</span>
                                        </td>
                                        <td class="text-muted" style="white-space: pre-line;">@meal.Content</td>
                                        <td class="pe-4 text-center">
                                            @if (meal.IsCompleted)
                                            {
                                                <div class="d-flex flex-column align-items-center justify-content-center">
                                                    <div class="text-success fw-bold mb-1">
                                                        <i class="bi bi-check-circle-fill fs-5 me-1"></i> Yedim
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(meal.ClientPhotoUrl))
                                                    {
                                                        <a href="@meal.ClientPhotoUrl" target="_blank" class="d-inline-block border border-success rounded-3 p-1 shadow-sm overflow-hidden bg-white" title="Kanıt Fotoğrafını Büyüt">
                                                            <img src="@meal.ClientPhotoUrl" alt="Öğün Kanıtı" style="width: 60px; height: 45px; object-fit: cover;" class="rounded-2" />
                                                        </a>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                if (isClient)
                                                {
                                                    <form asp-action="CompleteMeal" method="post" enctype="multipart/form-data" class="d-flex flex-column align-items-center bg-light p-2 rounded-3 border">
                                                        <input type="hidden" name="mealId" value="@meal.Id" />
                                                        <input type="file" name="photo" class="form-control form-control-sm mb-1" style="font-size: 0.7rem;" accept="image/*" title="Fotoğraf Yükle" />
                                                        <button type="submit" class="btn btn-success btn-sm w-100 rounded-pill fw-bold" style="font-size: 0.8rem;">
                                                            <i class="bi bi-check-lg"></i> İşaretle
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary bg-opacity-25 text-secondary rounded-pill px-2 pb-1">Bekleniyor</span>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    }
</div>
