@model DietitianApp.Models.DietList
@{
    ViewData["Title"] = "Diyet Listesi Ata";
}

<div class="row justify-content-center mt-3">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                <h4 class="fw-bold text-dark"><i class="bi bi-journal-plus text-primary me-2"></i> Yeni Diyet Listesi Ata</h4>
                <p class="text-muted small">Danışanınız <strong>@ViewBag.ClientName</strong> için bir beslenme programı hazırlıyorsunuz.</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Assign" method="post">
                    <input type="hidden" asp-for="ClientId" />
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Title" class="form-control focus-ring focus-ring-success" placeholder="Örn: 1. Hafta Detoks" required />
                        <label asp-for="Title">Listenin Başlığı</label>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6 form-floating">
                            <input asp-for="ValidFrom" type="date" class="form-control focus-ring focus-ring-success" required />
                            <label asp-for="ValidFrom" class="ms-2">Başlangıç Tarihi</label>
                        </div>
                        <div class="col-md-6 form-floating">
                            <input asp-for="ValidUntil" type="date" class="form-control focus-ring focus-ring-success" required />
                            <label asp-for="ValidUntil" class="ms-2">Bitiş Tarihi</label>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label text-muted fw-bold mb-0">Haftalık Öğün Tablosu</label>
                            <button type="button" class="btn btn-sm btn-outline-primary rounded-pill fw-bold" onclick="addMeal()">
                                <i class="bi bi-plus-lg"></i> Yeni Öğün Ekle (<span id="active-day-label">Pazartesi</span>)
                            </button>
                        </div>
                        
                        <!-- Gün Sekmeleri -->
                        <ul class="nav nav-pills nav-fill bg-light p-1 rounded-pill mb-3" id="dayTabs" role="tablist">
                            @{ var days = new[] { "Pazartesi", "Salı", "Çarşamba", "Perşembe", "Cuma", "Cumartesi", "Pazar", "Her Gün" }; }
                            @foreach(var day in days)
                            {
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link rounded-pill fw-medium @(day == "Pazartesi" ? "active" : "text-muted")" data-bs-toggle="pill" type="button" role="tab" onclick="switchDay('@day')">@day</button>
                                </li>
                            }
                        </ul>

                        <div class="table-responsive border rounded-3 shadow-sm bg-white">
                            <table class="table table-hover align-middle mb-0" id="diet-table">
                                <thead class="table-light text-muted">
                                    <tr>
                                        <th style="width: 15%" class="ps-3">Saat</th>
                                        <th style="width: 25%">Öğün Adı</th>
                                        <th style="width: 50%">İçerik Detayları</th>
                                        <th style="width: 10%" class="text-center pe-3">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody id="meals-container">
                                    @if (Model != null && Model.Meals != null && Model.Meals.Any())
                                    {
                                        int i = 0;
                                        foreach (var meal in Model.Meals)
                                        {
                                            <tr class="meal-item" id="meal-@i" data-day="@meal.DayName">
                                                <td class="ps-3 pb-3 align-top">
                                                    <input type="hidden" name="Meals[@i].DayName" class="day-name-input" value="@meal.DayName" />
                                                    <input name="Meals[@i].Time" value="@meal.Time.ToString(@"hh\:mm")" type="time" class="form-control form-control-sm focus-ring focus-ring-primary" required />
                                                </td>
                                                <td class="pb-3 align-top">
                                                    <input name="Meals[@i].MealName" value="@meal.MealName" type="text" class="form-control form-control-sm focus-ring focus-ring-primary" required />
                                                </td>
                                                <td class="pb-3 align-top">
                                                    <textarea name="Meals[@i].Content" class="form-control form-control-sm focus-ring focus-ring-primary" style="height: 60px" required>@meal.Content</textarea>
                                                </td>
                                                <td class="text-center pe-3 pb-3 align-top">
                                                    <button type="button" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" onclick="removeMeal(@i)" title="Öğünü Sil">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                            i++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div id="meals-empty-state" class="text-center py-4 bg-light rounded-bottom-3 text-muted border border-top-0" style="display:none;">
                            Henüz liste için öğün eklemediniz. Yukarıdaki butondan eklemeye başlayın.
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <a asp-controller="Dietitians" asp-action="Dashboard" class="btn btn-light rounded-pill px-4 me-2 fw-bold text-muted">İptal</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold" id="submitBtn">Listeyi Gönder</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let mealIndex = @((Model != null && Model.Meals != null) ? Model.Meals.Count : 0);
        let currentDay = 'Pazartesi';

        function switchDay(day) {
            currentDay = day;
            document.getElementById('active-day-label').innerText = day;
            
            // Sekme class geçişlerini düzenle
            document.querySelectorAll('#dayTabs .nav-link').forEach(btn => btn.classList.add('text-muted'));
            const activeBtn = Array.from(document.querySelectorAll('#dayTabs .nav-link')).find(btn => btn.innerText === day);
            if(activeBtn) activeBtn.classList.remove('text-muted');

            // Satırları filtrele
            let visibleCount = 0;
            document.querySelectorAll('.meal-item').forEach(row => {
                if (row.getAttribute('data-day') === day) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            if (visibleCount === 0) {
                document.getElementById('diet-table').parentElement.style.display = 'none';
                document.getElementById('meals-empty-state').style.display = 'block';
                document.getElementById('meals-empty-state').innerHTML = `<i class="bi bi-calendar-x d-block fs-3 mb-2"></i> <strong>${day}</strong> günü için henüz öğün eklemediniz.`;
            } else {
                document.getElementById('diet-table').parentElement.style.display = 'block';
                document.getElementById('meals-empty-state').style.display = 'none';
            }
        }

        function addMeal() {
            document.getElementById('meals-empty-state').style.display = 'none';
            document.getElementById('submitBtn').disabled = false;
            document.getElementById('diet-table').parentElement.style.display = 'block';

            const container = document.getElementById('meals-container');
            const mealHtml = `
                <tr class="meal-item" id="meal-${mealIndex}" data-day="${currentDay}">
                    <td class="ps-3 pb-3 align-top">
                        <input type="hidden" name="Meals[${mealIndex}].DayName" class="day-name-input" value="${currentDay}" />
                        <input name="Meals[${mealIndex}].Time" type="time" class="form-control form-control-sm focus-ring focus-ring-primary" required />
                    </td>
                    <td class="pb-3 align-top">
                        <input name="Meals[${mealIndex}].MealName" placeholder="Örn: Kahvaltı, 1. Ara Öğün" type="text" class="form-control form-control-sm focus-ring focus-ring-primary" required />
                    </td>
                    <td class="pb-3 align-top">
                        <textarea name="Meals[${mealIndex}].Content" class="form-control form-control-sm focus-ring focus-ring-primary" style="height: 60px" placeholder="Yiyecek ve porsiyon detayları..." required></textarea>
                    </td>
                    <td class="text-center pe-3 pb-3 align-top">
                        <button type="button" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" onclick="removeMeal(${mealIndex})" title="Öğünü Sil">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            `;
            container.insertAdjacentHTML('beforeend', mealHtml);
            mealIndex++;
        }

        function removeMeal(index) {
            const el = document.getElementById(`meal-${index}`);
            if (el) el.remove();
            
            // Re-index
            document.querySelectorAll('.meal-item').forEach((item, newIndex) => {
                item.id = `meal-${newIndex}`;
                item.querySelectorAll('.btn-outline-danger').forEach(btn => btn.setAttribute('onclick', `removeMeal(${newIndex})`));
                item.querySelectorAll('input, textarea').forEach(input => {
                    input.name = input.name.replace(/\[\d+\]/, `[${newIndex}]`);
                });
            });
            mealIndex = document.querySelectorAll('.meal-item').length;

            // Görünüm kontrolü
            switchDay(currentDay);
        }

        document.addEventListener("DOMContentLoaded", () => {
            if (mealIndex === 0) {
                addMeal();
                document.querySelector('input[name="Meals[0].Time"]').value = "08:30";
                document.querySelector('input[name="Meals[0].MealName"]').value = "Sabah Kahvaltısı";
            }
            switchDay('Pazartesi'); // Başlangıç render'ı
        });
    </script>
}
