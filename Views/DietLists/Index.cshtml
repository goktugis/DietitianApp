@model IEnumerable<DietitianApp.Models.DietList>
@{
    ViewData["Title"] = ViewBag.IsDietitian == true ? $"{ViewBag.DietitianClientName} - Diyet Listeleri" : "Diyet Listelerim";
    bool isDietitian = ViewBag.IsDietitian == true;

    var now = DateTime.Now.Date;
    var activeLists = Model.Where(l => l.ValidUntil.Date >= now).ToList();
    var pastLists = Model.Where(l => l.ValidUntil.Date < now).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold">
        <i class="bi bi-card-checklist me-2"></i> 
        @(isDietitian ? $"{ViewBag.DietitianClientName} İçin Listeler" : "Diyet Listelerim")
    </h2>
    <a href="@(isDietitian ? Url.Action("MyClients", "Dietitians") : Url.Action("Dashboard", "Clients"))" class="btn btn-outline-secondary rounded-pill fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Geri Dön
    </a>
</div>

<div class="row">
    <div class="col-12">
        @if (!Model.Any())
        {
            <div class="card shadow-sm border-0 rounded-4 text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
                <h5 class="text-muted">
                    @(isDietitian ? "Bu danışana henüz bir diyet atamadınız." : "Aman tanrım! Henüz size atanmış bir diyet listeniz bulunmuyor.")
                </h5>
                @if(isDietitian)
                {
                    <div class="mt-3">
                        <a href="@Url.Action("Assign", "DietLists", new { clientId = ViewBag.TargetClientId })" class="btn btn-primary rounded-pill">
                            <i class="bi bi-plus-circle me-1"></i> İlk Diyeti Ata
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            @if (activeLists.Any())
            {
                <h4 class="fw-bold text-dark mb-3"><i class="bi bi-calendar2-check text-success me-2"></i>Aktif Programlar</h4>
                <div class="row row-cols-1 row-cols-lg-2 g-4 mb-5">
                    @foreach(var item in activeLists)
                    {
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm rounded-4 border-start border-success border-5 position-relative">
                                <span class="position-absolute top-0 end-0 badge bg-success mt-3 me-3 rounded-pill px-3 py-2">Şu an Devam Ediyor</span>
                                <div class="card-body p-4">
                                    <h4 class="fw-bold text-dark mb-1">@item.Title</h4>
                                    <div class="text-muted small mb-3">
                                        <i class="bi bi-calendar3 me-1"></i> @item.ValidFrom.ToString("dd MMM") - @item.ValidUntil.ToString("dd MMM yyyy")
                                    </div>
                                    <p class="text-muted small mb-4" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @(string.IsNullOrEmpty(item.Content) ? "Genel not eklenmedi." : item.Content)
                                    </p>
                                    <div class="d-flex justify-content-between align-items-center mt-auto">
                                        <div class="text-muted small">
                                            @if(isDietitian) { <strong>Danışanınız Gösterimde</strong> }
                                            else { <strong>Diyetisyen:</strong> <span>@item.Dietitian?.Name @item.Dietitian?.Surname</span> }
                                        </div>
                                        <a href="@Url.Action("Details", "DietLists", new { id = item.Id })" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                                            <i class="bi bi-card-list me-1"></i> Görüntüle
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (pastLists.Any())
            {
                <h4 class="fw-bold text-muted mb-3"><i class="bi bi-archive text-secondary me-2"></i>Eski Programlar (Arşiv)</h4>
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                    @foreach(var item in pastLists)
                    {
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm bg-light rounded-4">
                                <div class="card-body p-3">
                                    <h6 class="fw-bold text-dark mb-1">@item.Title</h6>
                                    <div class="text-muted small mb-3">
                                        <i class="bi bi-calendar3 me-1"></i> @item.ValidFrom.ToString("dd/MM/yyyy") - @item.ValidUntil.ToString("dd/MM/yyyy")
                                    </div>
                                    <div class="d-grid mt-2">
                                        <a href="@Url.Action("Details", "DietLists", new { id = item.Id })" class="btn btn-outline-secondary btn-sm rounded-pill">
                                            <i class="bi bi-search me-1"></i> Arşivi Görüntüle
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>
