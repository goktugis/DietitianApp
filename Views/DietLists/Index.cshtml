@model IEnumerable<DietitianApp.Models.DietList>
@{
    ViewData["Title"] = "Diyet Listelerim";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold"><i class="bi bi-card-checklist me-2"></i> Diyet Listelerim</h2>
    <a asp-controller="Clients" asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Geri Dön
    </a>
</div>

<div class="row">
    <div class="col-12">
        @if (!Model.Any())
        {
            <div class="card shadow-sm border-0 rounded-4 text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
                <h5 class="text-muted">Aman tanrım! Henüz size atanmış bir diyet listeniz bulunmuyor.</h5>
            </div>
        }
        else
        {
            <div class="accordion accordion-flush shadow-sm rounded-4 overflow-hidden" id="dietListsAccordion">
                @{int index = 0;}
                @foreach(var item in Model)
                {
                    bool isCurrent = item.ValidFrom.Date <= DateTime.Now.Date && item.ValidUntil.Date >= DateTime.Now.Date;
                    
                    <div class="accordion-item border-bottom">
                        <h2 class="accordion-header" id="heading-@index">
                            <button class="accordion-button @(index == 0 ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@index" aria-expanded="true" aria-controls="collapse-@index">
                                <div class="d-flex align-items-center w-100 pe-3">
                                    <div class="flex-grow-1 fw-bold text-dark fs-5">
                                        @item.Title
                                        @if(isCurrent)
                                        {
                                            <span class="badge bg-success ms-2 rounded-pill px-2 py-1" style="font-size: 0.75rem;">Aktif Liste</span>
                                        }
                                    </div>
                                    <div class="text-muted small">
                                        <i class="bi bi-calendar3 me-1"></i> @item.ValidFrom.ToString("dd MMM") - @item.ValidUntil.ToString("dd MMM yyyy")
                                    </div>
                                </div>
                            </button>
                        </h2>
                        <div id="collapse-@index" class="accordion-collapse collapse @(index == 0 ? "show" : "")" aria-labelledby="heading-@index" data-bs-parent="#dietListsAccordion">
                            <div class="accordion-body p-4 bg-light">
                                <div class="bg-white p-4 rounded-4 shadow-sm border">
                                    <pre class="mb-0" style="white-space: pre-wrap; font-family: 'Poppins', sans-serif;">@item.Content</pre>
                                </div>
                                <div class="mt-3 text-end text-muted small">
                                    <strong>Diyetisyen:</strong> @item.Dietitian?.Name @item.Dietitian?.Surname
                                </div>
                            </div>
                        </div>
                    </div>
                    index++;
                }
            </div>
        }
    </div>
</div>
