@model DietitianApp.ViewModels.LoginViewModel
@{
    bool isDietitian = ViewBag.Role == "Dietitian";
    ViewData["Title"] = isDietitian ? "Diyetisyen Girişi" : "Danışan Girişi";
}

<div class="row justify-content-center align-items-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="mb-3">
                        @if(isDietitian) {
                            <i class="bi bi-briefcase-medical text-primary" style="font-size: 3rem;"></i>
                        } else {
                            <i class="bi bi-person-heart text-primary" style="font-size: 3rem;"></i>
                        }
                    </div>
                    <h2 class="text-primary fw-bold">@ViewData["Title"]</h2>
                    <p class="text-muted">Hesabınıza erişmek için bilgilerinizi girin.</p>
                </div>
                
                <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">
                    <input type="hidden" asp-for="ExpectedRole" value="@ViewBag.Role" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control focus-ring focus-ring-success" placeholder="name@example.com" />
                        <label asp-for="Email"></label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Password" class="form-control focus-ring focus-ring-success" placeholder="Şifre" />
                        <label asp-for="Password"></label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="RememberMe" />
                        <label class="form-check-label" asp-for="RememberMe">
                            @Html.DisplayNameFor(m => m.RememberMe)
                        </label>
                    </div>
                    
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">Giriş Yap</button>
                    </div>
                </form>
                
                <div class="text-center mt-4">
                    <p class="text-muted">Hesabınız yok mu? <a asp-action="Register" asp-route-role="@ViewBag.Role" class="text-primary fw-bold text-decoration-none">Kayıt Ol</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
