@{
    ViewData["Title"] = "Üyelik Tipi Seçimi";
    string islemGorseli = ViewBag.ActionType == "Login" ? "Giriş" : "Kayıt";
}

<div class="row justify-content-center align-items-center mt-5" style="min-height: 60vh;">
    <div class="col-12 text-center mb-5">
        <h1 class="display-5 fw-bold text-dark">Lütfen Hesap Türünüzü Seçin</h1>
        <p class="text-muted fs-5">Sisteme devam edebilmek için kimliğinizi doğrulayın.</p>
    </div>

    <div class="col-md-5 col-lg-4 mb-4">
        <a asp-action="@ViewBag.ActionType" asp-route-role="Client" class="text-decoration-none">
            <div class="card shadow-sm border-0 rounded-4 text-center h-100 card-hover-scale" style="transition: transform 0.3s;">
                <div class="card-body p-5">
                    <img src="https://cdni.iconscout.com/illustration/premium/thumb/healthy-diet-4487524-3738513.png" alt="Danışan" class="img-fluid mb-4" style="height: 150px;">
                    <h3 class="fw-bold text-dark">Danışan @islemGorseli</h3>
                    <p class="text-muted">Hedeflerinize ulaşmak, diyetisyeninizle görüşmek ve öğün takibi yapmak için.</p>
                    <div class="btn btn-outline-primary rounded-pill px-4 mt-3 fw-bold">Seç ve Devam Et</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-5 col-lg-4 mb-4">
        <a asp-action="@ViewBag.ActionType" asp-route-role="Dietitian" class="text-decoration-none">
            <div class="card shadow-sm border-0 rounded-4 text-center h-100 card-hover-scale" style="transition: transform 0.3s;">
                <div class="card-body p-5">
                    <img src="https://cdni.iconscout.com/illustration/premium/thumb/nutritionist-consultation-4487525-3738514.png" alt="Diyetisyen" class="img-fluid mb-4" style="height: 150px;">
                    <h3 class="fw-bold text-dark">Diyetisyen @islemGorseli</h3>
                    <p class="text-muted">Danışanlarınızı yönetmek, randevuları planlamak ve özel listeler hazırlamak için.</p>
                    <div class="btn btn-primary rounded-pill px-4 mt-3 fw-bold">Seç ve Devam Et</div>
                </div>
            </div>
        </a>
    </div>
</div>

<style>
.card-hover-scale:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 30px rgba(46, 139, 87, 0.15) !important;
}
</style>
