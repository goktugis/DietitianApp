@model DietitianApp.Models.DietitianProfile
@{
    ViewData["Title"] = "Diyetisyen Yönetim Paneli";
    
    var upcoming = ViewBag.UpcomingAppointments as IEnumerable<DietitianApp.Models.Appointment>;
    var clients = ViewBag.Clients as IEnumerable<DietitianApp.Models.ApplicationUser>;
}

<div class="row mb-4">
    <div class="col-md-8">
        <h2 class="fw-bold text-dark mb-1">Hoş Geldiniz, @Model.User?.Name! 👋</h2>
        <p class="text-muted fs-5">Randevularınızı ve danışanlarınızı buradan yönetebilirsiniz.</p>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <a asp-action="Calendar" class="btn btn-outline-info rounded-pill px-4 fw-bold me-2 shadow-sm">
            <i class="bi bi-calendar-week me-1"></i> Ajanda
        </a>
        <a asp-action="EditProfile" class="btn btn-outline-primary rounded-pill px-4 fw-bold shadow-sm">
            <i class="bi bi-person-gear me-1"></i> Profili Güncelle
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    <!-- Gelen & Yaklaşan Randevular -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-2 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold text-dark mb-0">Randevu Talepleri & Program</h5>
                <span class="badge bg-primary rounded-pill px-3 py-2">@upcoming?.Count() Randevu</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-muted small">
                            <tr>
                                <th class="ps-4">Danışan</th>
                                <th>Tarih / Saat</th>
                                <th>Durum</th>
                                <th class="pe-4 text-end">Aksiyon</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (upcoming == null || !upcoming.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted">
                                        <i class="bi bi-calendar-x fs-2 d-block mb-3"></i>
                                        Yaklaşan bir randevunuz bulunmuyor.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var appt in upcoming)
                                {
                                    <tr>
                                        <td class="ps-4 fw-medium">
                                            @appt.Client?.Name @appt.Client?.Surname
                                        </td>
                                        <td>
                                            <div class="fw-bold">@appt.AppointmentDate.ToString("dd MMM yyyy")</div>
                                            <div class="text-muted small">@appt.StartTime.ToString(@"hh\:mm")</div>
                                        </td>
                                        <td>
                                            @if(appt.Status == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark px-2 rounded-pill">Bekliyor</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success bg-opacity-10 text-success px-2 rounded-pill">@appt.Status</span>
                                            }
                                        </td>
                                        <td class="pe-4 text-end">
                                            @if (appt.Status == "Pending")
                                            {
                                                <form asp-controller="Appointments" asp-action="UpdateStatus" method="post" class="d-inline">
                                                    <input type="hidden" name="appointmentId" value="@appt.Id" />
                                                    <input type="hidden" name="status" value="Approved" />
                                                    <button type="submit" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm" title="Onayla">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                </form>
                                                <form asp-controller="Appointments" asp-action="UpdateStatus" method="post" class="d-inline ms-1">
                                                    <input type="hidden" name="appointmentId" value="@appt.Id" />
                                                    <input type="hidden" name="status" value="Cancelled" />
                                                    <button type="submit" class="btn btn-danger btn-sm rounded-pill px-3 shadow-sm" title="İptal Et">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <a href="/Chat?clientId=@appt.ClientId" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                                    <i class="bi bi-chat-dots me-1"></i> Mesaj
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Aktif Danışanlarım -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-2">
                <h5 class="fw-bold text-dark mb-0">Danışanlarım</h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @if (clients == null || !clients.Any())
                    {
                        <li class="list-group-item text-center py-4 text-muted border-0">
                            Henüz kayıtlı danışanınız yok.
                        </li>
                    }
                    else
                    {
                        foreach (var client in clients)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4 border-0 border-bottom">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px; font-weight: bold;">
                                        @(client.Name?.Substring(0,1))
                                    </div>
                                    <span class="fw-medium text-dark">@client.Name @client.Surname</span>
                                </div>
                                <div>
                                    <a href="/DietLists/Assign?clientId=@client.Id" class="btn btn-sm btn-outline-success rounded-pill px-2" title="Diyet Yaz">
                                        <i class="bi bi-journal-plus"></i>
                                    </a>
                                </div>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
