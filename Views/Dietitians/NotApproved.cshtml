@{
    ViewData["Title"] = "Onay Bekleniyor";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Admin layoutunu veya bos layout'u kullanma? Normal layout.
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="card shadow border-0 rounded-4 text-center p-5" style="max-width: 500px;">
        <i class="bi bi-hourglass-split text-warning mb-3" style="font-size: 4rem;"></i>
        <h2 class="fw-bold text-dark">Profiliniz Onay Sürecinde</h2>
        <p class="text-muted mt-3 mb-4">
            Diyetisyen kaydınız başarıyla alındı. Sertifika ve diploma onayınız yöneticilerimiz tarafından incelendikten sonra hesabınız aktif hale getirilecektir.
        </p>
        <div class="progress mb-4" style="height: 10px;">
          <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning w-50" role="progressbar" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
        <p class="small text-muted">Lütfen daha sonra tekrar kontrol edin veya e-postanızı takip edin.</p>
        
        <form asp-controller="Account" asp-action="Logout" method="post" class="mt-2">
            <button type="submit" class="btn btn-outline-primary rounded-pill px-4">Çıkış Yap</button>
        </form>
    </div>
</div>
