@model ErrorViewModel
@{
    ViewData["Title"] = "Bir Hata Oluştu";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="text-center">
        <div class="mb-4">
            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 6rem;"></i>
        </div>
        <h1 class="display-4 fw-bold text-dark mb-3">Eyvah! Bir şeyler ters gitti.</h1>
        <p class="text-muted fs-5 mb-4">İsteğinizi işlerken beklenmedik bir sunucu hatası oluştu. Lütfen daha sonra tekrar deneyin.</p>
        
        @if (Model.ShowRequestId)
        {
            <div class="alert alert-secondary d-inline-block text-start mb-4 shadow-sm" role="alert">
                <i class="bi bi-info-circle me-1"></i> <strong>Hata Takip ID:</strong> <code>@Model.RequestId</code>
            </div>
        }
        
        <div class="mt-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm">
                <i class="bi bi-house-door me-2"></i> Ana Sayfaya Dön
            </a>
        </div>
    </div>
</div>
