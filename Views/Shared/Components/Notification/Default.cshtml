@model IEnumerable<DietitianApp.Models.Notification>

@{
    var unreadCount = Model.Count(n => !n.IsRead);
}

<li class="nav-item dropdown me-3">
    <a class="nav-link dropdown-toggle d-flex align-items-center position-relative" href="#" id="navbarDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-bell-fill fs-5 text-dark"></i>
        @if (unreadCount > 0)
        {
            <span class="position-absolute top-10 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65em;">
                @unreadCount
                <span class="visually-hidden">Okunmamış bildirim</span>
            </span>
        }
    </a>
    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4" aria-labelledby="navbarDropdownMenuLink" style="width: 320px; max-height: 400px; overflow-y: auto;">
        <li><h6 class="dropdown-header fw-bold text-dark border-bottom pb-2 mb-2">Bildirimleriniz</h6></li>
        
        @if (!Model.Any())
        {
            <li><span class="dropdown-item text-muted text-center py-3 small">Hiç bildiriminiz yok.</span></li>
        }
        else
        {
            foreach (var notif in Model)
            {
                <li class="mb-1">
                    <a class="dropdown-item py-2 px-3 @(notif.IsRead ? "text-muted" : "fw-bold bg-light")" 
                       href="@(notif.ActionUrl ?? "#")" 
                       onclick="@(!notif.IsRead ? $"markAsRead({notif.Id})" : "")">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <span class="text-truncate d-block" style="max-width: 250px;">
                                @if(!notif.IsRead) { <i class="bi bi-circle-fill text-primary" style="font-size: 0.5rem; margin-right: 4px; vertical-align: middle;"></i> }
                                @notif.Title
                            </span>
                        </div>
                        <small class="d-block text-wrap" style="font-size: 0.8em; line-height: 1.3;">@notif.Message</small>
                        <small class="text-muted mt-1 d-block" style="font-size: 0.7em;">@notif.CreatedAt.ToString("g")</small>
                    </a>
                </li>
            }
        }
    </ul>
</li>

<script>
    function markAsRead(id) {
        fetch('/Notifications/MarkAsRead/' + id, {
            method: 'POST'
        }).then(() => {
            // İlgili UI hemen etkisini gösterilebilir (İsteğe bağlı reload)
        }).catch(err => console.error(err));
    }
</script>
