@{
    ViewData["Title"] = "Sayfa Bulunamadı - 404";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="text-center">
        <div class="mb-4 position-relative d-inline-block">
            <i class="bi bi-search text-muted opacity-25" style="font-size: 8rem;"></i>
            <span class="position-absolute top-50 start-50 translate-middle text-primary fw-bold" style="font-size: 3rem; text-shadow: 2px 2px 0 #fff;">404</span>
        </div>
        <h1 class="display-5 fw-bold text-dark mb-3">Aradığınız Sayfa Bulunamadı!</h1>
        <p class="text-muted fs-5 mb-5 mx-auto" style="max-width: 500px;">
            Görünüşe göre bu sayfa sağlıklı beslenme programımızın dışında kalmış. Adresi yanlış yazmış olabilirsiniz veya sayfa taşınmış olabilir.
        </p>
        
        <div>
            <button onclick="history.back()" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold me-2 shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Geri Dön
            </button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm">
                <i class="bi bi-house-door me-2"></i> Ana Sayfaya Dön
            </a>
        </div>
    </div>
</div>
