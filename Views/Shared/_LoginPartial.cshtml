@using Microsoft.AspNetCore.Identity
@using DietitianApp.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var isDietitian = user != null && await UserManager.IsInRoleAsync(user, "Dietitian");
    var isAdmin = user != null && await UserManager.IsInRoleAsync(user, "Admin");

    <li class="nav-item pe-2">
        <span class="nav-link text-primary fw-bold d-flex align-items-center">
            @if (!string.IsNullOrEmpty(user?.ProfileImageUrl))
            {
                <img src="@user.ProfileImageUrl" alt="Profil" class="rounded-circle me-2 shadow-sm border border-1 border-primary" style="width: 32px; height: 32px; object-fit: cover;" />
            }
            Hoş geldin, @(user?.Name ?? user?.UserName)!
        </span>
    </li>
    
    @if(isAdmin)
    {
        <li class="nav-item">
            <a class="nav-link text-danger fw-bold" asp-area="Admin" asp-controller="Home" asp-action="Index">
                <i class="bi bi-shield-lock-fill"></i> Admin Paneli
            </a>
        </li>
    }
    else if(isDietitian)
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="Dietitians" asp-action="Dashboard">
                <i class="bi bi-clipboard2-pulse"></i> Diyetisyen Paneli
            </a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="Clients" asp-action="Dashboard">
                <i class="bi bi-person-fill"></i> Danışan Paneli
            </a>
        </li>
    }

    <li class="nav-item ms-2">
        <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="btn btn-outline-danger btn-sm mt-1 rounded-pill">
                <i class="bi bi-box-arrow-right"></i> Çıkış Yap
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="SelectRole" asp-route-actionType="Login">Giriş Yap</a>
    </li>
    <li class="nav-item ms-2">
        <a class="btn btn-primary btn-sm mt-1 rounded-pill px-3" asp-area="" asp-controller="Account" asp-action="SelectRole" asp-route-actionType="Register">Kayıt Ol</a>
    </li>
}
